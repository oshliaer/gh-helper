            path=$(echo "$comment" | jq -r '.path // "No path"')
            line_number=$(echo "$comment" | jq -r '.line // "No line"')

            echo "├── Comment ID: $id"
            echo "│   ├── Author: $author"
            echo "│   ├── Created: $created_at"
            echo "│   ├── Location: $path:$line_number"
            echo "│   └── Comment:"
            # Print comment body with proper indentation
            echo "$body" | sed 's/^/│      /'
            echo "│"
            ((count++))
        done
    else
