        count=0
        jq -c '.[]' "$TEMP_REVIEWS" | while IFS= read -r review; do
            if [ $COUNT_LIMIT -ne -1 ] && [ $count -ge $COUNT_LIMIT ]; then
                return
            fi

            id=$(echo "$review" | jq -r '.id')
            author=$(echo "$review" | jq -r '.user.login')
            state=$(echo "$review" | jq -r '.state')
            body=$(echo "$review" | jq -r '.body // "No body"')
            submitted_at=$(echo "$review" | jq -r '.submitted_at')

            echo "├── Review ID: $id"
            echo "│   ├── Author: $author"
            echo "│   ├── Status: $state"
            echo "│   ├── Submitted: $submitted_at"
            echo "│   └── Review:"
            # Print review body with proper indentation
            echo "$body" | sed 's/^/│      /'
            echo "│"
            ((count++))
        done
    else
        echo "No reviews found"
        echo "│"
    fi
}

