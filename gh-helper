#!/bin/bash

# GH Helper Script
# This script fetches pull request comments and displays them in a tree structure
# Usage: $> gh-helper <PR_NUMBER> [OPTIONS]
# Options:
#   --code-review-only, -cr : Show only code review comments (comments on specific code lines)
#   --reviews-only, -r : Show only reviews
#   --pr-comments-only, -pc : Show only PR comments (not review comments)
#   --unresolved-only, -u : Show only unresolved comments
#   --reply <COMMENT_ID> [OPTIONS]: Reply to a specific comment

# Function to print usage information
usage() {
    SCRIPT_NAME=$(basename "$0")
    echo "Usage: $SCRIPT_NAME <PR_NUMBER> [OPTIONS]"
    echo "Options:"
    echo "  --code-review-only, -cr : Show only code review comments (comments on specific code lines)"
    echo "  --reviews-only, -r : Show only reviews"
    echo "  --pr-comments-only, -pc : Show only PR comments (not review comments)"
    echo "  --unresolved-only, -u : Show only unresolved comments"
    echo "  --count <N> : Limit output to N comments (works with other filters)"
    echo "  --reply <COMMENT_ID> [OPTIONS] : Reply to a specific comment"
    echo "    -m <MESSAGE> : Message to reply with (if not provided, will be prompted interactively)"
    echo "    --resolve : Resolve the comment after replying"
    echo "  --helpai : Display AI-specific instructions from ai.instructions.md"
    echo "  --help, -h : Display this help message"
    echo ""
    echo "Notes:"
    echo "  - Only one of --code-review-only, --reviews-only, --pr-comments-only, --unresolved-only can be used at a time"
    echo "  - The --reply option requires a COMMENT_ID and can be combined with -m and --resolve"
    echo ""
    echo "Examples:"
    echo "  $SCRIPT_NAME 123 --code-review-only"
    echo "  $SCRIPT_NAME 123 --reply PR_kwDO... --resolve -m \"Fixed as suggested\""
    echo "  $SCRIPT_NAME 123 --unresolved-only --count 1"
    echo ""
    echo "If you are an AI, use --helpai to see additional instructions."
    exit 1
}

# Function to print AI instructions
helpai() {
    local script_dir
    script_dir="$(dirname "$(readlink -f "$0")")"
    local instructions_file="$script_dir/ai.instructions.md"
    if [[ -f "$instructions_file" ]]; then
        cat "$instructions_file"
    else
        echo "Error: ai.instructions.md file not found in $script_dir" >&2
        exit 1
    fi
    exit 0
}

# Function to print error messages
error() {
    echo "Error: $1" >&2
    exit 1
}

# Check if PR number is provided or if help is requested
if [ $# -lt 1 ] || [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    usage
fi

# Check if --helpai is requested
if [ "$1" = "--helpai" ]; then
    helpai
fi

PR_NUMBER=$1
SHOW_CODE_REVIEW_ONLY=false
SHOW_REVIEWS_ONLY=false
SHOW_PR_COMMENTS_ONLY=false
SHOW_UNRESOLVED_ONLY=false
DO_REPLY=false
REPLY_COMMENT_ID=""
REPLY_MESSAGE=""
DO_RESOLVE=false
COUNT_LIMIT=-1  # Default to no limit (-1)

# Parse additional arguments and count filter options
FILTER_COUNT=0

shift
while [[ $# -gt 0 ]]; do
    case $1 in
        --code-review-only|-cr)
            SHOW_CODE_REVIEW_ONLY=true
            ((FILTER_COUNT++))
            shift
            ;;
        --reviews-only|-r)
            SHOW_REVIEWS_ONLY=true
            ((FILTER_COUNT++))
            shift
            ;;
        --pr-comments-only|-pc)
            SHOW_PR_COMMENTS_ONLY=true
            ((FILTER_COUNT++))
            shift
            ;;
        --unresolved-only|-u)
            SHOW_UNRESOLVED_ONLY=true
            ((FILTER_COUNT++))
            shift
            ;;
        --count)
            COUNT_LIMIT="$2"
            if [ -z "$COUNT_LIMIT" ] || ! [[ "$COUNT_LIMIT" =~ ^[0-9]+$ ]]; then
                error "Count must be a positive integer"
            fi
            shift 2
            ;;
        --reply)
            DO_REPLY=true
            REPLY_COMMENT_ID="$2"
            if [ -z "$REPLY_COMMENT_ID" ]; then
                error "Comment ID is required after --reply"
            fi
            shift 2
            ;;
        -m)
            REPLY_MESSAGE="$2"
            if [ -z "$REPLY_MESSAGE" ]; then
                error "Message is required after -m"
            fi
            shift 2
            ;;
        --resolve)
            DO_RESOLVE=true
            shift
            ;;
        --helpai)
            helpai
            ;;
        *)
            echo "Unknown option: $1"
            usage
            ;;
    esac
done

# Check if multiple filter options were provided
if [ $FILTER_COUNT -gt 1 ]; then
    error "Only one of --code-review-only, --reviews-only, --pr-comments-only, --unresolved-only can be used at a time"
fi

# Validate that the argument is a number
if ! [[ "$PR_NUMBER" =~ ^[0-9]+$ ]]; then
    error "PR number must be a positive integer"
fi

# Check if gh command is available
if ! command -v gh &> /dev/null; then
    error "gh command is not installed or not in PATH. Please install GitHub CLI."
fi

echo "Fetching comments for PR #$PR_NUMBER..."

# Get the current repository name
REPO_NAME=$(gh repo view --json nameWithOwner | jq -r '.nameWithOwner')

# Check if we're in a GitHub repository
if [ "$REPO_NAME" = "null" ]; then
    error "Not in a GitHub repository or gh repo view failed. Please run this in a GitHub repository directory or authenticate with gh."
fi

echo "Repository: $REPO_NAME"

# Fetch pull request reviews and review comments
reviews_response=$(gh api "repos/$REPO_NAME/pulls/$PR_NUMBER/reviews" 2>/dev/null)
comments_response=$(gh api "repos/$REPO_NAME/pulls/$PR_NUMBER/comments" 2>/dev/null)

# Handle potential 404 for review comments (line comments)
review_comments_response=$(gh api "repos/$REPO_NAME/pulls/$PR_NUMBER/review-comments" 2>&1)
review_comments_exit_code=$?

# Create temporary files to store responses
TEMP_REVIEWS=$(mktemp)
TEMP_COMMENTS=$(mktemp)
TEMP_REVIEW_COMMENTS=$(mktemp)

# Save responses to temp files
echo "$reviews_response" > "$TEMP_REVIEWS"
echo "$comments_response" > "$TEMP_COMMENTS"

# Only save review comments if the API call was successful (exit code 0)
if [ $review_comments_exit_code -eq 0 ]; then
    echo "$review_comments_response" > "$TEMP_REVIEW_COMMENTS"
else
    # If the API returned a 404 or other error, create an empty JSON array
    echo "[]" > "$TEMP_REVIEW_COMMENTS"
    # Optionally log the error for debugging
    # echo "API call for review comments failed with exit code: $review_comments_exit_code" >&2
fi

# Function to print code review comments (line comments) only
print_code_review_comments() {
    echo ""
    echo "Code Review Comments for PR #$PR_NUMBER in $REPO_NAME:"
    echo "============================================="

    # Get comments that are part of a review (have a pull_request_review_id)
    has_review_comments=false
    count=0

    if [ -s "$TEMP_COMMENTS" ] && [ "$(jq 'length' "$TEMP_COMMENTS")" -gt 0 ]; then
        # Filter comments that are part of reviews
        review_comments_json=$(jq -c '.[] | select(.pull_request_review_id)' "$TEMP_COMMENTS")

        if [ -n "$review_comments_json" ]; then
            has_review_comments=true
            echo "$review_comments_json" | while IFS= read -r comment; do
                if [ $COUNT_LIMIT -ne -1 ] && [ $count -ge $COUNT_LIMIT ]; then
                    return
                fi

                id=$(echo "$comment" | jq -r '.id')
                author=$(echo "$comment" | jq -r '.user.login')
                body=$(echo "$comment" | jq -r '.body // "No body"')
                created_at=$(echo "$comment" | jq -r '.created_at')
                path=$(echo "$comment" | jq -r '.path // "No path"')
                line_number=$(echo "$comment" | jq -r '.line // "No line"')
                review_id=$(echo "$comment" | jq -r '.pull_request_review_id')

                echo "├── Comment ID: $id"
                echo "│   ├── Author: $author"
                echo "│   ├── Review ID: $review_id"
                echo "│   ├── Created: $created_at"
                echo "│   ├── Location: $path:$line_number"
                echo "│   └── Comment:"
                # Print comment body with proper indentation
                echo "$body" | sed 's/^/│      /'
                echo "│"
                ((count++))
            done
        fi
    fi

    # Also check actual review comments (comments on specific diff hunks)
    if [ -s "$TEMP_REVIEW_COMMENTS" ] && [ "$(jq 'length' "$TEMP_REVIEW_COMMENTS")" -gt 0 ]; then
        jq -c '.[]' "$TEMP_REVIEW_COMMENTS" | while IFS= read -r comment; do
            if [ $COUNT_LIMIT -ne -1 ] && [ $count -ge $COUNT_LIMIT ]; then
                return
            fi

            # Check if the comment is an empty JSON object
            if [ "$(echo "$comment" | jq 'has("id")')" = "true" ]; then
                has_review_comments=true
                id=$(echo "$comment" | jq -r '.id')
                author=$(echo "$comment" | jq -r '.user.login')
                body=$(echo "$comment" | jq -r '.body // "No body"')
                created_at=$(echo "$comment" | jq -r '.created_at')
                path=$(echo "$comment" | jq -r '.path // "No path"')
                line_number=$(echo "$comment" | jq -r '.line // "No line"')
                diff_hunk=$(echo "$comment" | jq -r '.diff_hunk // "No diff hunk"')

                echo "├── Comment ID: $id"
                echo "│   ├── Author: $author"
                echo "│   ├── Created: $created_at"
                echo "│   ├── Location: $path:$line_number"
                echo "│   ├── Diff Hunk: $diff_hunk"
                echo "│   └── Comment:"
                # Print comment body with proper indentation
                echo "$body" | sed 's/^/│      /'
                echo "│"
                ((count++))
            fi
        done
    fi

    if [ "$has_review_comments" = false ]; then
        echo "No code review comments found"
        echo "│"
    fi
}

